# ─── E2E test configuration ────────────────────────────────────────────
# Sao chép file này thành `e2e/.env.test` rồi điền thông tin DB test của bạn.
# Quan trọng: DB_NAME PHẢI kết thúc bằng "_test" để tránh chạy nhầm trên DB
# production (seed script sẽ DROP toàn bộ schema rồi recreate).

# ─── Test database ──────────────────────────────────────────────────────
# Option 1: Docker Postgres (khuyến nghị — `docker compose up -d` trong e2e/)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=uknow_campaign_test
DB_USER=postgres
DB_PASSWORD=postgres

# Option 2: Postgres local (nếu đã cài sẵn)
# DB_PORT=5432
# DB_PASSWORD=<password local của bạn>

# Option 3: Neon test branch (cloud)
# DB_HOST=ep-xxx-pooler.c-2.ap-southeast-1.aws.neon.tech
# DB_PORT=5432
# DB_NAME=neondb_test
# DB_USER=neondb_owner
# DB_PASSWORD=<neon-test-branch-password>
# DB_SSL=true
# PGSSLMODE=require

# ─── Backend test config ────────────────────────────────────────────────
# Các giá trị này sẽ override backend/.env khi Playwright spawn backend
PORT=5001
NODE_ENV=test
JWT_SECRET=e2e-jwt-secret-not-for-production
JWT_REFRESH_SECRET=e2e-jwt-refresh-secret-not-for-production
JWT_EXPIRES_IN=3h
JWT_REFRESH_EXPIRES_IN=7d

# Tắt BullMQ để khỏi cần Redis trong test
BULLMQ_ENABLED=false

# Tắt external services (Zalo, SendGrid, PayOS) — E2E không gọi tới
SENDGRID_API_KEY=
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
GEMINI_API_KEY=

FRONTEND_URL=http://localhost:5174
BACKEND_PUBLIC_URL=http://localhost:5001

# ─── E2E test user ──────────────────────────────────────────────────────
# Seed script sẽ tạo user này, các spec dùng để login
E2E_USERNAME=e2etest
E2E_PASSWORD=Test@1234
E2E_EMAIL=e2etest@uknow.test
