#!/usr/bin/env sh
# UKNOW pre-push hook
# --------------------
# Chạy unit test backend trước khi push để catch regression nhanh (5–10s)
# thay vì đợi CI 60s+.
#
# Skip khi:
#   - Push không có file backend nào thay đổi.
#   - Push tới branch không phải feature (vd. main/develop — CI tự gate).
#   - Dev cần khẩn cấp:  `git push --no-verify`
#
# Integration test KHÔNG chạy ở đây vì cần Postgres local.
# CI sẽ luôn chạy integration trên service container.

REMOTE="$1"
URL="$2"

# Nếu không có thay đổi backend → bỏ qua hook hoàn toàn
if ! git diff --name-only @{push}..HEAD 2>/dev/null | grep -q '^backend/'; then
  # Fallback cho branch mới chưa từng push: so với origin/main
  base_ref=$(git merge-base HEAD origin/main 2>/dev/null)
  if [ -z "$base_ref" ] || ! git diff --name-only "$base_ref"..HEAD | grep -q '^backend/'; then
    echo "[pre-push] Không có thay đổi backend — skip unit test."
    exit 0
  fi
fi

echo "[pre-push] Chạy backend unit test trước khi push..."
echo "[pre-push] Bỏ qua nhanh:  git push --no-verify"
echo ""

cd backend || exit 1

if ! npm run test:unit --silent -- --ci; then
  echo ""
  echo "[pre-push] ❌ Unit test FAIL — fix trước hoặc dùng --no-verify để bypass."
  exit 1
fi

echo ""
echo "[pre-push] ✅ Unit test pass — tiến hành push."
