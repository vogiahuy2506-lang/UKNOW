#!/usr/bin/env sh
# UKNOW pre-push hook
# --------------------
# Chạy nhanh các test có thể chạy không cần Postgres local trước khi push để
# catch regression sớm (5–10s) thay vì đợi CI 60s+.
#
# Skip khi:
#   - Push không có file backend/frontend thay đổi.
#   - Dev cần khẩn cấp:  `git push --no-verify`
#
# Backend integration test KHÔNG chạy ở đây vì cần Postgres local.
# CI sẽ luôn chạy integration trên service container.

# Tìm base ref để so sánh: trước hết là remote tracking, fallback merge-base với origin/main.
DIFF_BASE=$(git rev-parse @{push} 2>/dev/null)
if [ -z "$DIFF_BASE" ]; then
  DIFF_BASE=$(git merge-base HEAD origin/main 2>/dev/null)
fi
if [ -z "$DIFF_BASE" ]; then
  echo "[pre-push] Không xác định được base ref — bỏ qua hook."
  exit 0
fi

CHANGED=$(git diff --name-only "$DIFF_BASE"..HEAD)
HAS_BACKEND=$(echo "$CHANGED" | grep -c '^backend/' || true)
HAS_FRONTEND=$(echo "$CHANGED" | grep -c '^frontend/' || true)

if [ "$HAS_BACKEND" -eq 0 ] && [ "$HAS_FRONTEND" -eq 0 ]; then
  echo "[pre-push] Không có thay đổi backend/frontend — skip test."
  exit 0
fi

echo "[pre-push] Bỏ qua nhanh:  git push --no-verify"

if [ "$HAS_BACKEND" -gt 0 ]; then
  echo "[pre-push] Chạy backend unit test..."
  (cd backend && npm run test:unit --silent -- --ci) || {
    echo ""
    echo "[pre-push] ❌ Backend unit test FAIL — fix trước hoặc dùng --no-verify để bypass."
    exit 1
  }
  echo "[pre-push] ✅ Backend unit test pass."
fi

if [ "$HAS_FRONTEND" -gt 0 ]; then
  echo "[pre-push] Chạy frontend Vitest..."
  (cd frontend && npm run test:run --silent) || {
    echo ""
    echo "[pre-push] ❌ Frontend test FAIL — fix trước hoặc dùng --no-verify để bypass."
    exit 1
  }
  echo "[pre-push] ✅ Frontend test pass."
fi

echo ""
echo "[pre-push] ✅ Tất cả nhanh-test pass — tiến hành push."
