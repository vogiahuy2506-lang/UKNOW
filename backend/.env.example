DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=3h
JWT_REFRESH_EXPIRES_IN=7d


UKNOW_API_URL=
UKNOW_CONSUMER_KEY=
UKNOW_CONSUMER_SECRET=
WC_WEBHOOK_SECRET=

# Local file storage (attachments sẽ lưu trong backend/uploads)
BACKEND_PUBLIC_URL=http://localhost:5001

FRONTEND_URL=http://:5174
FRONTEND_URLS=https://v1..id.vn

TRACKING_BASE_URL=https://v1-api..id.vn

WC_WEBHOOK_USER_ID=1
MAX_CONCURRENT_CAMPAIGNS=3
# Số continuous campaigns được phép xử lý nodes đồng thời (sleeping campaigns không tính).
# VPS 4vCore/8GB RAM: khuyến nghị 10-15.
MAX_CONTINUOUS_WORKERS=10
DB_POOL_MAX=25

# Thời gian tối đa (ms) mỗi câu SQL trong transaction lưu khách node save_customer (mặc định 600000). 0 = tắt timeout cục bộ.
# SAVE_CUSTOMERS_STATEMENT_TIMEOUT_MS=600000

# BullMQ + Redis cho tác vụ gửi outbound (email/zalo/friend request)
BULLMQ_ENABLED=true
BULLMQ_REDIS_URL=redis://127.0.0.1:6379
BULLMQ_WORKER_CONCURRENCY=8
BULLMQ_JOB_ATTEMPTS=4
BULLMQ_WAIT_RESULT_TIMEOUT_MS=300000
BULLMQ_RATE_LIMIT_MAX=20
BULLMQ_RATE_LIMIT_DURATION_MS=1000

# Đọc Google Sheet (link công khai) — timeout HTTP, nhường CPU khi parse, worker BullMQ
# READ_SHEET_FETCH_TIMEOUT_MS: thời gian tối đa mỗi request tải htmlview/CSV (mặc định code 180000 = 3 phút; ví dụ dưới 10 phút cho sheet lớn)
# READ_SHEET_PARSE_YIELD_EVERY_ROWS: cứ N dòng map xong thì nhường event loop (mặc định 500)
# READ_SHEET_USE_BULLMQ: true = tải+parse trên worker queue (khuyến nghị khi sheet lớn ~10k+ dòng); cần Redis
# READ_SHEET_BULLMQ_WAIT_TIMEOUT_MS: chờ job sheet hoàn tất (nên >= tải + parse; ví dụ 20 phút cho sheet ~15k dòng)
READ_SHEET_FETCH_TIMEOUT_MS=600000
READ_SHEET_PARSE_YIELD_EVERY_ROWS=500
READ_SHEET_USE_BULLMQ=true
READ_SHEET_BULLMQ_WAIT_TIMEOUT_MS=1200000

# Tối ưu chế độ continuous khi gửi số lượng lớn (email/zalo)
CONTINUOUS_EMAIL_BATCH_SIZE=12
CONTINUOUS_ZALO_PERSONAL_BATCH_SIZE=1
CONTINUOUS_ZALO_FRIEND_BATCH_SIZE=1
CONTINUOUS_ZALO_GROUP_BATCH_SIZE=1
# true nếu muốn giữ random delay ở continuous; false để ưu tiên throughput.
CONTINUOUS_RANDOM_DELAY_ENABLED=false

# Zalo outbound (cá nhân / nhóm / kết bạn):
# - Giới hạn theo mỗi tài khoản Zalo + từng kênh (zalo_personal / zalo_group / zalo_friend_request)
# - Mặc định: 100 tin/giờ, cách nhau ngẫu nhiên 50–80 giây giữa hai tin
# - Không gửi trong khung 23:00–06:00; nếu rơi vào khung này sẽ tự delay sang 06:00
ZALO_OUTBOUND_PER_HOUR_LIMIT_DEFAULT=100
ZALO_OUTBOUND_RATE_WINDOW_MS=3600000
ZALO_OUTBOUND_INTER_MESSAGE_MIN_MS_DEFAULT=50000
ZALO_OUTBOUND_INTER_MESSAGE_MAX_MS_DEFAULT=80000
ZALO_OUTBOUND_QUIET_HOURS_START=23
ZALO_OUTBOUND_QUIET_HOURS_END=6

# Chờ Zalo (hết quota/giờ yên lặng/cooldown tra số) >= N ms thì nhả slot campaign; scheduler resume sau (mặc định 60000).
ZALO_OUTBOUND_YIELD_SLOT_MIN_WAIT_MS=180000

# Override theo kênh (nếu muốn):
ZALO_PERSONAL_PER_HOUR_LIMIT=100
ZALO_PERSONAL_INTER_MESSAGE_MIN_MS=50000
ZALO_PERSONAL_INTER_MESSAGE_MAX_MS=80000
# Khi Zalo báo tra số quá nhiều / hoạt động bất thường / "Vượt quá số request cho phép": cooldown toàn tài khoản cho kênh cá nhân (ms). Mặc định 3 giờ.
ZALO_PERSONAL_PHONE_LOOKUP_COOLDOWN_MS=10800000
ZALO_GROUP_PER_HOUR_LIMIT=100
ZALO_GROUP_INTER_MESSAGE_MIN_MS=50000
ZALO_GROUP_INTER_MESSAGE_MAX_MS=80000
ZALO_FRIEND_REQUEST_PER_HOUR_LIMIT=100
ZALO_FRIEND_REQUEST_INTER_MESSAGE_MIN_MS=50000
ZALO_FRIEND_REQUEST_INTER_MESSAGE_MAX_MS=80000

# Tương thích ngược (legacy) cho Zalo cá nhân (nếu hệ thống cũ còn dùng):
# - `ZALO_PERSONAL_BLOCK_SEND_LIMIT` + `ZALO_PERSONAL_BLOCK_COOLDOWN_MS` sẽ được map sang limit/window của kênh cá nhân.
# - Khuyến nghị dùng các biến mới phía trên.
ZALO_PERSONAL_BLOCK_SEND_LIMIT=100
ZALO_PERSONAL_BLOCK_COOLDOWN_MS=3600000

# Rate-limit gửi email theo SMTP account (emails/phút)
SMTP_RATE_LIMIT_PER_MINUTE_ACCOUNT=60
# Có thể override theo account cụ thể bằng key dạng SMTP_RATE_LIMIT_PER_MINUTE_ACCOUNT_<settingsId>
# Ví dụ: SMTP_RATE_LIMIT_PER_MINUTE_ACCOUNT_12=80

# Gemini (Insight dashboard) — chỉ cấu hình ở BACKEND, không đưa xuống frontend
GEMINI_API_KEY=
# Mặc định code: gemini-2.0-flash (tránh 404 với tên model cũ như gemini-1.5-flash không suffix)
GEMINI_MODEL=gemini-2.0-flash