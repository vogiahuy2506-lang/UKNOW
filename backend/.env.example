DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=3h
JWT_REFRESH_EXPIRES_IN=7d

# Khóa riêng mã hóa mật khẩu SMTP trong DB (AES-256-GCM). Bắt buộc — không dùng chung JWT_SECRET.
SMTP_SECRET_KEY=

# Platform sender domain — all emails go out from no-reply@DEFAULT_FROM_DOMAIN unless domain is SendGrid-verified
DEFAULT_FROM_DOMAIN=founderai.biz

# SendGrid SMTP & Web API
SENDGRID_API_KEY=
SENDGRID_SMTP_HOST=smtp.sendgrid.net
SENDGRID_SMTP_PORT=587
SENDGRID_SMTP_USERNAME=apikey


UKNOW_API_URL=
UKNOW_CONSUMER_KEY=
UKNOW_CONSUMER_SECRET=
WC_WEBHOOK_SECRET=

BACKEND_PUBLIC_URL=http://localhost:5001

FRONTEND_URL=http://localhost:5174
FRONTEND_URLS=https://v1..id.vn,https://uknow.edu.vn,https://www.uknow.edu.vn,https://founderai.biz

TRACKING_BASE_URL=https://v1-api..id.vn


WC_WEBHOOK_USER_ID=1
MAX_CONCURRENT_CAMPAIGNS=3
MAX_CONTINUOUS_WORKERS=10
DB_POOL_MAX=25

BULLMQ_ENABLED=true
BULLMQ_REDIS_URL=redis://127.0.0.1:6379
BULLMQ_REDIS_CONNECT_TIMEOUT_MS=60000
BULLMQ_WORKER_CONCURRENCY=8
BULLMQ_JOB_ATTEMPTS=4
BULLMQ_WAIT_RESULT_TIMEOUT_MS=60000
BULLMQ_RATE_LIMIT_MAX=20
BULLMQ_RATE_LIMIT_DURATION_MS=1000


READ_SHEET_FETCH_TIMEOUT_MS=600000
READ_SHEET_PARSE_YIELD_EVERY_ROWS=500
READ_SHEET_USE_BULLMQ=true
READ_SHEET_BULLMQ_WAIT_TIMEOUT_MS=1200000

CONTINUOUS_EMAIL_BATCH_SIZE=12
CONTINUOUS_ZALO_PERSONAL_BATCH_SIZE=1
CONTINUOUS_ZALO_FRIEND_BATCH_SIZE=1
CONTINUOUS_ZALO_GROUP_BATCH_SIZE=1
CONTINUOUS_RANDOM_DELAY_ENABLED=false


ZALO_OUTBOUND_PER_HOUR_LIMIT_DEFAULT=100
ZALO_OUTBOUND_RATE_WINDOW_MS=3600000
ZALO_OUTBOUND_INTER_MESSAGE_MIN_MS_DEFAULT=80000
ZALO_OUTBOUND_INTER_MESSAGE_MAX_MS_DEFAULT=150000
ZALO_OUTBOUND_QUIET_HOURS_START=23
ZALO_OUTBOUND_QUIET_HOURS_END=6

ZALO_OUTBOUND_YIELD_SLOT_MIN_WAIT_MS=180000



NON_CONTINUOUS_YIELD_SLOT_MIN_WAIT_MS=1800000

CONTINUOUS_ZALO_MAX_SEND_FAILURES=5

ZALO_PERSONAL_PER_HOUR_LIMIT=100
ZALO_PERSONAL_INTER_MESSAGE_MIN_MS=80000
ZALO_PERSONAL_INTER_MESSAGE_MAX_MS=150000
ZALO_PERSONAL_PHONE_LOOKUP_COOLDOWN_MS=10800000
ZALO_GROUP_PER_HOUR_LIMIT=100
ZALO_GROUP_INTER_MESSAGE_MIN_MS=80000
ZALO_GROUP_INTER_MESSAGE_MAX_MS=150000
ZALO_FRIEND_REQUEST_PER_HOUR_LIMIT=100
ZALO_FRIEND_REQUEST_INTER_MESSAGE_MIN_MS=80000
ZALO_FRIEND_REQUEST_INTER_MESSAGE_MAX_MS=150000


ZALO_PERSONAL_BLOCK_SEND_LIMIT=100
ZALO_PERSONAL_BLOCK_COOLDOWN_MS=3600000

SMTP_RATE_LIMIT_PER_MINUTE_ACCOUNT=60


GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

PRIVACY_POLICY_URL=https://campaign.digiso.vn/privacy-policy

# Facebook OAuth & Webhook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CLIENT_TOKEN=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=founderai

# Zalo OA OAuth
ZALO_OA_APP_ID=
ZALO_OA_APP_SECRET=

# OAuth Callback URL (public)
OAUTH_CALLBACK_URL=https://api.founderai.biz/api/webhooks/oauth/callback

# OAuth state secret for CSRF protection
OAUTH_STATE_SECRET=your-random-secret-here

# Cloudflare API for DNS automation
CLOUDFLARE_API_TOKEN=

# Landing Page Domain Configuration
# Base domain for auto-provisioned subdomains (e.g., slug.founderai.biz)
LP_SUBDOMAIN_BASE=founderai.biz
# CNAME target for all custom subdomains (where the CNAME points to)
LP_CNAME_TARGET=founderai.biz
# Fixed IP address for apex domain A records (the server's public IP where the platform runs)
# Get this IP by running: nslookup founderai.biz
LP_APEX_FIXED_IP=
# Path to SSL auto-provision script inside the backend container
SSL_PROVISION_SCRIPT=/opt/uknow/ssl-auto-provision.sh