# Sao chép thành `.env.test` (gitignored) nếu muốn override toàn bộ.
# Nếu không có file này: globalSetup đọc DB_* từ e2e/.env.test hoặc e2e/.env.test.example
# (Docker E2E: port 5433, mật khẩu postgres) cho các biến DB còn trống.
#
# Tạo database (Postgres local không dùng Docker): CREATE DATABASE uknow_campaign_test;

DB_NAME=uknow_campaign_test
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
