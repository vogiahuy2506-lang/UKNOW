{
  "name": "uknow-campaign-backend",
  "version": "1.0.0",
  "description": "UKNOW Campaign Management Backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "dev:e2e": "DOTENV_CONFIG_PATH=../e2e/.env.test nodemon -r dotenv/config src/index.js",
    "start:e2e": "DOTENV_CONFIG_PATH=../e2e/.env.test node -r dotenv/config src/index.js",
    "start": "node src/index.js",
    "seed": "node scripts/seed.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects=unit",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects=unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects=integration --runInBand --forceExit --testTimeout=20000",
    "test:all": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit --coverage"
  },
  "jest": {
    "transform": {},
    "clearMocks": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/config/**",
      "!src/**/__tests__/**",
      "!src/**/*.spec.js"
    ],
    "coverageReporters": [
      "text-summary",
      "lcov",
      "html",
      "json-summary"
    ],
    "coverageDirectory": "coverage",
    "projects": [
      {
        "displayName": "unit",
        "testEnvironment": "node",
        "transform": {},
        "clearMocks": true,
        "testMatch": [
          "<rootDir>/src/**/__tests__/**/*.spec.js",
          "<rootDir>/src/**/*.spec.js"
        ]
      },
      {
        "displayName": "integration",
        "testEnvironment": "node",
        "transform": {},
        "clearMocks": true,
        "setupFilesAfterEnv": [
          "<rootDir>/tests/integration/jest-timeout.js"
        ],
        "testMatch": [
          "<rootDir>/tests/integration/**/*.test.js"
        ],
        "globalSetup": "<rootDir>/tests/integration/setup.js",
        "globalTeardown": "<rootDir>/tests/integration/teardown.js"
      }
    ]
  },
  "keywords": [
    "campaign",
    "marketing",
    "email",
    "zalo"
  ],
  "author": "UKNOW",
  "license": "MIT",
  "dependencies": {
    "@payos/node": "^2.0.5",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "papaparse": "^5.5.3",
    "pg": "^8.11.3",
    "undici": "^7.24.7",
    "uuid": "^9.0.1",
    "zca-js": "2.1.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
