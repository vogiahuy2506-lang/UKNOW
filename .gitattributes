# Force LF line endings cho shell scripts — quan trọng cho husky hooks
# vì bash trên macOS/Linux không parse được CRLF.
*.sh        text eol=lf
.husky/*    text eol=lf

# Code files: dùng auto để git tự xử text/binary
*           text=auto
backend/src/services/campaign/campaignRun.service.js whitespace=cr-at-eol
backend/src/services/campaign/campaignZaloSender.service.js whitespace=cr-at-eol
backend/src/services/campaign/campaignEmailSender.service.js whitespace=cr-at-eol
backend/src/controllers/zaloSettings.controller.js whitespace=cr-at-eol

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.xlsx      binary
*.zip       binary
